# DeepSeek API Key（必填）
# 在此填入你的真实 API Key，本地测试时复制此文件为 .env
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# API 基础地址（可选，默认值如下）
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 模型名称（可选，默认 deepseek-chat）
# DEEPSEEK_MODEL=deepseek-chat

# 系统提示词（可选）
# SYSTEM_PROMPT=You are a helpful assistant.

# 允许跨域请求的前端域名，多个用逗号分隔（可选，默认允许本地开发）
# ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# API 鉴权 Token（可选，用于防止接口被随意调用）
# AUTH_TOKEN=your-secret-auth-token

# HMAC 签名密钥（可选，配合前端时间戳+签名防止抓包重放）
# SIGN_SECRET=your-sign-secret-key
